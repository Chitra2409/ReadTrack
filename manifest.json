{
  "manifest_version": 3,
  "name": "ReadTrack",
  "version": "0.1.0",
  "description": "Track time spent reading across the web. Categorized by site type.",

  "permissions": [
    "tabs",
    "storage",
    "idle",
    "webNavigation"
  ],

  "background": {
    "service_worker": "background/service-worker.js"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "ReadTrack",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },

  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  }
}
